        "url": {
          "raw": "{{BASE_URL}}/automations/create-automation",
          "host": ["{{BASE_URL}}"],
          "path": ["automations", "create-automation"]
        }
      }
    },
    {
      "name": "17. Test Invalid URL",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
