          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Invalid URL Test\",\n  \"targetUrl\": \"not-a-valid-url\",\n  \"schedule\": \"* * * * *\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/automations/create-automation",
