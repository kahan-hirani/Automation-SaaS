# Application
NODE_ENV=development
PORT=3000
# Optional: run BullMQ worker in same process as API (useful for single free service)
RUN_WORKER_IN_API=false

# Frontend domains allowed to call API (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=automation_saas
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false
# Optional: managed Postgres URL (takes priority if set)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false
# Optional: managed Redis URL (takes priority if set)
# REDIS_URL=redis://default:password@host:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
EMAIL_FROM="Automation SaaS <noreply@automation-saas.com>"

# For development (Ethereal Email - fake SMTP)
ETHEREAL_USER=test@ethereal.email
ETHEREAL_PASS=test123

# Logging
LOG_LEVEL=info

# Optional AI key
GROQ_API_KEY=your_groq_api_key
